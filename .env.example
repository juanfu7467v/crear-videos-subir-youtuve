# ═══════════════════════════════════════════════════════════════
# El Tío Jota - Auto Video System
# Variables de entorno (.env)
# COPIA este archivo como .env y llena los valores
# ═══════════════════════════════════════════════════════════════

# ─── IA - Gemini (REQUERIDO) ─────────────────────────────────────
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu_gemini_api_key_aqui

# ─── Media - Pexels (REQUERIDO para clips) ───────────────────────
# Obtener en: https://www.pexels.com/api/
PEXELS_API_KEY=tu_pexels_api_key_aqui

# ─── Media - Pixabay (REQUERIDO para clips adicionales) ──────────
# Obtener en: https://pixabay.com/api/docs/
PIXABAY_API_KEY=tu_pixabay_api_key_aqui

# ─── YouTube (REQUERIDO para publicar) ───────────────────────────
# Obtener en: https://console.cloud.google.com/
# 1. Crear proyecto
# 2. Activar YouTube Data API v3
# 3. Crear credenciales OAuth2 (Desktop app)
# 4. Descargar JSON y guardarlo como credentials/youtube_credentials.json
YOUTUBE_CREDENTIALS_FILE=credentials/youtube_credentials.json

# ─── Canal ────────────────────────────────────────────────────────
CHANNEL_NAME=El Tío Jota

# ─── Modo de ejecución ───────────────────────────────────────────
# once     = Ejecutar una vez y terminar
# scheduled = Ejecutar según SCHEDULE_TIMES
# server   = Servidor HTTP + scheduler (para Fly.io)
RUN_MODE=server

# ─── Horario de publicación ──────────────────────────────────────
# Formato: HH:MM,HH:MM (zona horaria según TIMEZONE)
SCHEDULE_TIMES=08:00,18:00

# ─── Zona horaria ────────────────────────────────────────────────
TIMEZONE=America/Mexico_City

# ─── TTS - Voz por defecto ───────────────────────────────────────
# Opciones: es-MX-DaliaNeural, es-MX-JorgeNeural, es-ES-ElviraNeural
# es-AR-ElenaNeural, es-CO-SalomeNeural
DEFAULT_VOICE=es-MX-DaliaNeural
DEFAULT_SPEECH_RATE=+10%
DEFAULT_PITCH=+0Hz

# ─── Video ────────────────────────────────────────────────────────
BG_MUSIC_VOLUME=0.08
USE_SUBTITLES=true

# ─── Control de calidad ──────────────────────────────────────────
# Score mínimo para publicar (0-100)
MIN_QC_SCORE=60

# ─── Servidor ─────────────────────────────────────────────────────
PORT=8080
API_SECRET_KEY=cambia-este-secreto-muy-largo-y-seguro

# ─── Logs ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO
